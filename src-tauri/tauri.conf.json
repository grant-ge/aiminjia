{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AIjia",
  "version": "0.3.21",
  "identifier": "com.aijia.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "AI小家 — 组织专家，工作助手",
        "width": 1280,
        "height": 800,
        "minWidth": 1080,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data: asset: https:"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://lotus.renlijia.com/aijia/update.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU4MDE3N0E5NkIwMjM5RjcKUldUM09RSnJxWGNCV1BwcVQxVWovL1R4T3dVYmlZL004ZFYrRkNubi8rd0Y1cHBLd3BEc2trUXAK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "python-runtime": "python-runtime",
      "prompts": "prompts",
      "plugins": "plugins"
    }
  }
}
